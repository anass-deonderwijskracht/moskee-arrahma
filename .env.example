# Supabase — frontend (browser) configuration.
# Only the anon key is exposed to the browser bundle. NEVER put the
# service_role key in a VITE_* variable — it would ship to every visitor.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# --- Dev tooling only (NOT read by the frontend; keep out of VITE_*) ---
# Used by scripts that apply migrations / seed / create the first admin.
# Rotate this key before go-live.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
